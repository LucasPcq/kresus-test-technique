{
  "name": "kresus",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "latest",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "@vee-validate/zod>zod": "4"
      }
    }
  },
  "dependencies": {}
}
