{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useConst": "error",
        "noUnusedTemplateLiteral": "warn",
        "useImportType": "off"
      },
      "correctness": {
        "noUnusedImports": "error"
      }
    }
  },
  "files": {
    "ignore": ["node_modules", "dist", ".turbo", ".next", "routeTree.gen.ts"]
  }
}
